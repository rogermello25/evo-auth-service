# =============================================================================
# Evo AI Community — Docker Internal Network Overrides
# =============================================================================
# These vars override root .env.example when running inside docker-compose.
# Do NOT use localhost — use service container names as hostnames.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Service (Go / Gin) — internal Docker URL
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=evoai_dev_password
DB_NAME=evo_community
DB_SSLMODE=disable
PORT=5555
EVOLUTION_BASE_URL=http://evo-crm:3000
EVO_AUTH_BASE_URL=http://evo-auth:3001
AI_PROCESSOR_URL=http://evo-processor:8000

# -----------------------------------------------------------------------------
# Processor (Python / FastAPI) — internal Docker URL
# -----------------------------------------------------------------------------
POSTGRES_CONNECTION_STRING=postgresql://postgres:evoai_dev_password@postgres:5432/evo_community
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=evoai_redis_pass
REDIS_SSL=false
HOST=0.0.0.0
PORT=8000
EVO_AI_CRM_URL=http://evo-crm:3000
CORE_SERVICE_URL=http://evo-core:5555/api/v1

# -----------------------------------------------------------------------------
# Bot Runtime (Go / Gin) — listen on all interfaces inside container
# -----------------------------------------------------------------------------
# NOTE: docker-compose sets LISTEN_ADDR=0.0.0.0:8080 directly on the container
# This is the override for the evo-bot-runtime service .env.example which defaults to :8090
LISTEN_ADDR=0.0.0.0:8080

# -----------------------------------------------------------------------------
# CRM (Ruby / Rails) — internal Docker URLs
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
REDIS_URL=redis://:evoai_redis_pass@redis:6379/0
EVO_AUTH_SERVICE_URL=http://evo-auth:3001
EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
BOT_RUNTIME_URL=http://evo-bot-runtime:8080
BOT_RUNTIME_SECRET=evo-bot-runtime-dev-secret
BOT_RUNTIME_POSTBACK_BASE_URL=http://evo-crm:3000

# -----------------------------------------------------------------------------
# Frontend (React / Vite) — BUILD-time vars (browser accesses localhost in dev)
# -----------------------------------------------------------------------------
# VITE_ vars are baked in at build time; the browser calls services directly.
# In Docker, the frontend is accessed via localhost:5173 on the host, so
# VITE_ vars remain as localhost for browser-side requests.
VITE_APP_ENV=development
VITE_API_URL=http://localhost:3000
VITE_AUTH_API_URL=http://localhost:3001
VITE_EVOAI_API_URL=http://localhost:5555
VITE_AGENT_PROCESSOR_URL=http://localhost:8000